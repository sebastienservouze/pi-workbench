{
  "name": "pi-workbench",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite --host 127.0.0.1",
    "dev:backend": "node --watch server/backend.ts",
    "dev:manager": "node --watch server/manager.ts",
    "start:backend": "node server/backend.ts",
    "start:manager": "node server/manager.ts",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc -b",
    "lint": "oxlint .",
    "test": "node --test",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
